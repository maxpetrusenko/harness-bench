{
  "id": "continue",
  "kind": "cli",
  "parse": "text",
  "cwdMode": "workspace",
  "command": ["cn", "-p", "{prompt}"],
  "modelArgs": ["--model", "{model}"],
  "capabilities": {
    "edits_files": true,
    "runs_shell": true,
    "reads_images": false,
    "mcp": true,
    "browser": false,
    "lsp": false,
    "git_native": false,
    "headless": true,
    "supports_model_flag": true
  },
  "lifecycle": {
    "version": ["cn", "--version"],
    "install": ["npm install -g @continuedev/cli"],
    "uninstall": ["npm uninstall -g @continuedev/cli"],
    "notes": "Continue CLI headless mode. Requires configured model/provider and tool permissions."
  }
}
