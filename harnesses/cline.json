{
  "id": "cline",
  "kind": "cli",
  "parse": "cline-json",
  "cwdMode": "workspace",
  "command": ["cline", "--json", "--cwd", "{workspace}", "{prompt}"],
  "modelArgs": ["--model", "{model}"],
  "capabilities": {
    "edits_files": true,
    "runs_shell": true,
    "reads_images": true,
    "mcp": true,
    "browser": true,
    "lsp": true,
    "git_native": false,
    "headless": true,
    "supports_model_flag": true
  },
  "lifecycle": {
    "version": ["cline", "version"],
    "install": ["npm install -g cline"],
    "uninstall": ["npm uninstall -g cline"],
    "notes": "Open-source Cline CLI. Requires provider auth in ~/.cline before scored runs."
  }
}
