{
  "id": "opencode",
  "kind": "cli",
  "parse": "opencode-jsonl",
  "cwdMode": "workspace",
  "command": ["opencode", "run", "--format", "json", "{prompt}"],
  "modelArgs": ["-m", "{model}"],
  "modelArgsIndex": 2,
  "capabilities": {
    "edits_files": true,
    "runs_shell": true,
    "reads_images": false,
    "mcp": true,
    "browser": false,
    "lsp": false,
    "git_native": false,
    "headless": true,
    "supports_model_flag": true
  },
  "lifecycle": {
    "version": ["opencode", "--version"],
    "install": ["Install OpenCode from official opencode docs"],
    "uninstall": ["remove the opencode CLI using the same package manager used for install"],
    "notes": "OpenRouter/provider credentials must be configured before scored runs."
  }
}
