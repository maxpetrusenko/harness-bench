{
  "id": "qwen-code",
  "kind": "cli",
  "parse": "text",
  "cwdMode": "workspace",
  "command": ["qwen", "-p", "{prompt}", "-y"],
  "modelArgs": ["--model", "{model}"],
  "capabilities": {
    "edits_files": true,
    "runs_shell": true,
    "reads_images": true,
    "mcp": true,
    "browser": false,
    "lsp": false,
    "git_native": false,
    "headless": true,
    "supports_model_flag": true
  },
  "lifecycle": {
    "version": ["qwen", "--version"],
    "install": ["npm install -g @qwen-code/qwen-code"],
    "uninstall": ["npm uninstall -g @qwen-code/qwen-code"],
    "notes": "Qwen Code headless mode. -y is only for isolated benchmark workspaces."
  }
}
