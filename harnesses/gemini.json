{
  "id": "gemini",
  "kind": "cli",
  "parse": "gemini-json",
  "cwdMode": "workspace",
  "command": ["gemini", "--yolo", "-o", "json", "-p", "{prompt}"],
  "modelArgs": ["-m", "{model}"],
  "capabilities": {
    "edits_files": true,
    "runs_shell": true,
    "reads_images": true,
    "mcp": false,
    "browser": false,
    "lsp": false,
    "git_native": false,
    "headless": true,
    "supports_model_flag": true
  },
  "lifecycle": {
    "version": ["gemini", "--version"],
    "install": ["Install Gemini CLI from official Google docs"],
    "uninstall": ["remove the Gemini CLI using the same package manager used for install"],
    "notes": "Requires Gemini CLI authentication before scored runs."
  }
}
